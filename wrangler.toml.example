name = "maccount-api"
main = "src/index.ts"
compatibility_date = "2024-11-01"
compatibility_flags = ["nodejs_compat"]

[[d1_databases]]
binding = "DB"
database_name = "maccount"
database_id = "e42cb79c-1753-4311-ab13-610ac717f602"

[vars]
PUBLIC_BASE_URL = "https://maccount-api.<subdomain>.workers.dev"
FRONTEND_DONE_URL = "https://skhuang.github.io/maccount/done.html"
NYCU_AUTHORIZE_URL = "https://id.nycu.edu.tw/o/authorize/"
NYCU_TOKEN_URL = "https://id.nycu.edu.tw/o/token/"
NYCU_USERINFO_URL = "https://id.nycu.edu.tw/api/profile/"
NYCU_SCOPE = "profile"
GITHUB_CLIENT_ID = ""
# Google OAuth client id (secrets GOOGLE_CLIENT_SECRET + GOOGLE_TOKEN_KEY via
# `wrangler secret put`). Enable the Google Drive API + Forms API on this project.
GOOGLE_CLIENT_ID = ""
# OAuth scope at consent. Empty → identity + drive.file. Staff "connect Drive"
# (/auth/google/start?drive=1) additionally requests full drive + forms.body.
GOOGLE_SCOPE = "openid email https://www.googleapis.com/auth/drive.file"
NYCU_CLIENT_ID = ""
ADMIN_IDS = ""
COURSE_ORG = "nycu-cs-course-ds"
# Org team slug for TA/staff; must match dsjudge's OJ_PROVISION_TEAM.
STAFF_TEAM = "staff"
# Default course-offering id for back-compat (non-course-scoped /admin + grade
# ingests without an explicit course_id fall back to this). Code default: ds-2026.
DEFAULT_COURSE_ID = "ds-2026"
